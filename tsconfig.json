{
  "include": ["src/**/*.ts"],
  "compilerOptions": {
    "moduleResolution": "nodenext",
    "noImplicitAny": true,
    "declaration": true,
    "strict": true,
    "target": "esnext",
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "nodenext",
    "esModuleInterop": true,
    "isolatedModules": true
  }
}
